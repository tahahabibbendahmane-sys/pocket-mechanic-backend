{
  "expo": {
    "name": "pocket-mechanic",
    "slug": "pocket-mechanic",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pocketmechanic",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
      "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.energia.pocketmechanic",
      "buildNumber": "7",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Pocket Mechanic uses your location to detect when you finish a drive, so it can remind you to update your mileage.",
        "NSLocationWhenInUseUsageDescription": "Pocket Mechanic uses your location to detect drives and remind you to update your mileage.",
        "UIBackgroundModes": ["location"],
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.444087067992-og9qic1c23aetvruae7ncpai834vbppj"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/icon.png",
        "backgroundImage": "./assets/images/icon.png",
        "monochromeImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "versionCode": 1
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0567A6",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-localization",
      "@react-native-community/datetimepicker",
      "@react-native-google-signin/google-signin",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Pocket Mechanic uses your location to detect when you finish a drive, so it can remind you to update your mileage.",
          "locationWhenInUsePermission": "Pocket Mechanic uses your location to detect drives and remind you to update your mileage.",
          "isIosBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0567A6",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "deepseekApiKey": "YOUR_DEEPSEEK_API_KEY_HERE",
      "router": {},
      "eas": {
        "projectId": "bf7d4f82-a08f-427e-a4c5-22e8cb4a4e4d"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/bf7d4f82-a08f-427e-a4c5-22e8cb4a4e4d"
    }
  }
}
